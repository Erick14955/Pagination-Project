@inherits LayoutComponentBase
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="thryv-dashboard-layout">
    <div class="thryv-sidebar-overlay @(sidebarOpen ? "show" : "")" @onclick="CloseSidebar"></div>

    <aside class="thryv-sidebar @(sidebarOpen ? "open" : "closed")">
        <div class="thryv-sidebar-header">
            <div class="thryv-brand-block">
                <div class="thryv-brand-mark">T</div>
                <div class="thryv-brand-text">
                    <h3>Evaluations</h3>
                    <p>Pagination evaluation system</p>
                </div>
            </div>

            <button type="button" class="thryv-sidebar-close" @onclick="CloseSidebar" title="Close menu">
                ✕
            </button>
        </div>

        <AuthorizeView>
            <Authorized Context="auth">
                <nav class="thryv-sidebar-menu">
                    <NavLink href="/dashboard" Match="NavLinkMatch.All" class="thryv-menu-link">
                        <span class="thryv-menu-icon">📊</span>
                        <span class="thryv-menu-text">Dashboard</span>
                    </NavLink>

                    @if (HasPermission(auth.User, "CreateUser") || HasPermission(auth.User, "EditUser") || HasPermission(auth.User, "DeleteUser"))
                    {
                        <NavLink href="/usuarios" class="thryv-menu-link">
                            <span class="thryv-menu-icon">👥</span>
                            <span class="thryv-menu-text">Users</span>
                        </NavLink>
                    }

                    @if (HasPermission(auth.User, "CreateEmployees") || HasPermission(auth.User, "EditEmployees") || HasPermission(auth.User, "DeleteEmployees"))
                    {
                        <NavLink href="/empleados" class="thryv-menu-link">
                            <span class="thryv-menu-icon">👤</span>
                            <span class="thryv-menu-text">Employees</span>
                        </NavLink>
                    }

                    @if (HasPermission(auth.User, "CreateBook") || HasPermission(auth.User, "EditBook") || HasPermission(auth.User, "DeleteBook") || HasPermission(auth.User, "BooksView"))
                    {
                        <NavLink href="/libros" class="thryv-menu-link">
                            <span class="thryv-menu-icon">📖</span>
                            <span class="thryv-menu-text">Books</span>
                        </NavLink>
                    }

                    @if (HasPermission(auth.User, "QualifyBook"))
                    {
                        <NavLink href="/evaluaciones" class="thryv-menu-link">
                            <span class="thryv-menu-icon">⭐</span>
                            <span class="thryv-menu-text">Evaluations</span>
                        </NavLink>
                    }

                    @if (HasPermission(auth.User, "AsignBook") || HasPermission(auth.User, "ViewAssignations"))
                    {
                        <NavLink href="/asignaciones" class="thryv-menu-link">
                            <span class="thryv-menu-icon">📌</span>
                            <span class="thryv-menu-text">Assignments</span>
                        </NavLink>
                    }

                    @if (HasPermission(auth.User, "EditPermissionLevels"))
                    {
                        <NavLink href="/permisos" class="thryv-menu-link">
                            <span class="thryv-menu-icon">🛡️</span>
                            <span class="thryv-menu-text">Permissions</span>
                        </NavLink>
                    }
                </nav>
            </Authorized>
        </AuthorizeView>
    </aside>

    <main class="thryv-main-content">
        <header class="thryv-top-header">
            <div class="thryv-header-left">
                <button type="button" class="thryv-menu-toggle" @onclick="ToggleSidebar" title="Show or hide menu">
                    ☰
                </button>

                <div class="thryv-header-title">
                    <h1>Evaluations</h1>
                    <span>Dashboard workspace</span>
                </div>
            </div>

            <AuthorizeView>
                <Authorized Context="auth">
                    <div class="thryv-user-info">
                        <div class="thryv-user-badge">
                            <div class="thryv-user-avatar">👤</div>
                            <div class="thryv-user-details">
                                <span class="thryv-user-label">@ObtenerRol(auth.User)</span>
                                <span class="thryv-user-name">@GetDisplayName(auth.User)</span>
                            </div>
                        </div>

                        <form method="post" action="/account/logout">
                            <button type="submit" class="thryv-logout-btn">Sign Out</button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </header>

        <section class="thryv-page-content">
            @Body
        </section>
    </main>
</div>

@code {
    private bool sidebarOpen = true;
    private ClaimsPrincipal? _user;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;
    }

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private void CloseSidebar()
    {
        sidebarOpen = false;
    }

    private static bool HasPermission(ClaimsPrincipal user, string claimType)
    {
        return string.Equals(user.FindFirst(claimType)?.Value, "True", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetDisplayName(ClaimsPrincipal user)
    {
        return user.Identity?.Name
               ?? user.FindFirst(ClaimTypes.Name)?.Value
               ?? user.FindFirst("Username")?.Value
               ?? "User";
    }

    private static string ObtenerRol(ClaimsPrincipal user)
    {
        var lvlId = user.FindFirst("LvlId")?.Value;

        return lvlId switch
        {
            "1" => "Administrator",
            "2" => "Supervisor",
            "3" => "Assistant",
            "4" => "User",
            _ => "Usuario autenticado"
        };
    }
}