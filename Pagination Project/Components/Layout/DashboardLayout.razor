@inherits LayoutComponentBase
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="dashboard-layout">
    <div class="sidebar-overlay @(sidebarOpen ? "show" : "")" @onclick="CerrarSidebar"></div>

    <aside class="sidebar @(sidebarOpen ? "open" : "closed")">
        <div class="sidebar-header">
            <div class="brand-block">
                <h3>📚 BibliotecaApp</h3>
                <p>Panel de Control</p>
            </div>

            <button type="button" class="sidebar-close" @onclick="CerrarSidebar" title="Cerrar menú">
                ✕
            </button>
        </div>

        <AuthorizeView>
            <Authorized Context="auth">
                <nav class="sidebar-menu">
                    <NavLink href="/dashboard" Match="NavLinkMatch.All" class="menu-link">
                        <span class="menu-icon">📊</span>
                        <span class="menu-text">Dashboard</span>
                    </NavLink>

                    @if (TienePermiso(auth.User, "CreateUser") || TienePermiso(auth.User, "EditUser") || TienePermiso(auth.User, "DeleteUser"))
                    {
                        <NavLink href="/usuarios" class="menu-link">
                            <span class="menu-icon">👥</span>
                            <span class="menu-text">Usuarios</span>
                        </NavLink>
                    }

                    @if (TienePermiso(auth.User, "CreateEmployees") || TienePermiso(auth.User, "EditEmployees") || TienePermiso(auth.User, "DeleteEmployees"))
                    {
                        <NavLink href="/empleados" class="menu-link">
                            <span class="menu-icon">👤</span>
                            <span class="menu-text">Empleados</span>
                        </NavLink>
                    }

                    @if (TienePermiso(auth.User, "CreateBook") || TienePermiso(auth.User, "EditBook") || TienePermiso(auth.User, "DeleteBook") || TienePermiso(auth.User, "BooksView"))
                    {
                        <NavLink href="/libros" class="menu-link">
                            <span class="menu-icon">📖</span>
                            <span class="menu-text">Libros</span>
                        </NavLink>
                    }

                    @if (TienePermiso(auth.User, "QualifyBook"))
                    {
                        <NavLink href="/evaluaciones" class="menu-link">
                            <span class="menu-icon">⭐</span>
                            <span class="menu-text">Evaluaciones</span>
                        </NavLink>
                    }

                    @if (TienePermiso(auth.User, "AsignBook") || TienePermiso(auth.User, "ViewAssignations"))
                    {
                        <NavLink href="/asignaciones" class="menu-link">
                            <span class="menu-icon">📌</span>
                            <span class="menu-text">Asignaciones</span>
                        </NavLink>
                    }

                    @if (TienePermiso(auth.User, "EditPermissionLevels"))
                    {
                        <NavLink href="/permisos" class="menu-link">
                            <span class="menu-icon">🛡️</span>
                            <span class="menu-text">Permisos</span>
                        </NavLink>
                    }
                </nav>
            </Authorized>
        </AuthorizeView>
    </aside>

    <main class="main-content">
        <header class="top-header">
            <div class="header-left">
                <button type="button" class="menu-toggle" @onclick="ToggleSidebar" title="Mostrar u ocultar menú">
                    ☰
                </button>

                <div class="header-title">
                    <h1>BibliotecaApp</h1>
                </div>
            </div>

            <AuthorizeView>
                <Authorized Context="auth">
                    <div class="user-info">
                        <div class="user-badge">
                            <div class="user-avatar">👤</div>
                            <div class="user-details">
                                <span class="user-name">@ObtenerNombre(auth.User)</span>
                            </div>
                        </div>

                        <form method="post" action="/account/logout">
                            <button type="submit" class="logout-btn">Cerrar Sesión</button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </header>

        <section class="page-content">
            @Body
        </section>
    </main>
</div>

@code {
    private bool sidebarOpen = true;
    private ClaimsPrincipal? _usuario;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _usuario = authState.User;
    }

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private void CerrarSidebar()
    {
        sidebarOpen = false;
    }

    private static bool TienePermiso(ClaimsPrincipal user, string claimType)
    {
        return string.Equals(user.FindFirst(claimType)?.Value, "True", StringComparison.OrdinalIgnoreCase);
    }

    private static string ObtenerNombre(ClaimsPrincipal user)
    {
        return user.Identity?.Name
               ?? user.FindFirst(ClaimTypes.Name)?.Value
               ?? user.FindFirst("Username")?.Value
               ?? "User";
    }
}