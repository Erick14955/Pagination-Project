@page "/dashboard"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Pagination_Project.Models
@using Pagination_Project.Services
@inject IDashboardService DashboardService
@layout Pagination_Project.Components.Layout.DashboardLayout
@rendermode InteractiveServer

<PageTitle>Dashboard - Evaluations</PageTitle>

<div class="thryv-dashboard-page">
    <div class="thryv-dashboard-header">
        <div>
            <h2 class="thryv-dashboard-title">General Dashboard</h2>
            <p class="thryv-dashboard-subtitle">
                Quick system summary and current list of assigned books.
            </p>
        </div>
    </div>

    @if (loading)
    {
        <div class="thryv-loading-card">
            <div class="thryv-loading-text">Loading statistics...</div>
        </div>
    }
    else
    {
        <div class="thryv-stats-grid">
            <div class="thryv-stat-card">
                <div class="thryv-stat-info">
                    <span class="thryv-stat-label">Total Users</span>
                    <div class="thryv-stat-number">@stats.TotalUsers</div>
                </div>
                <div class="thryv-stat-icon users">👥</div>
            </div>

            <div class="thryv-stat-card">
                <div class="thryv-stat-info">
                    <span class="thryv-stat-label">Total Employees</span>
                    <div class="thryv-stat-number">@stats.TotalEmployees</div>
                </div>
                <div class="thryv-stat-icon employees">👤</div>
            </div>

            <div class="thryv-stat-card">
                <div class="thryv-stat-info">
                    <span class="thryv-stat-label">Total Books</span>
                    <div class="thryv-stat-number">@stats.TotalBooks</div>
                </div>
                <div class="thryv-stat-icon books">📚</div>
            </div>

            <div class="thryv-stat-card">
                <div class="thryv-stat-info">
                    <span class="thryv-stat-label">Total Evaluations</span>
                    <div class="thryv-stat-number">@stats.TotalEvaluations</div>
                </div>
                <div class="thryv-stat-icon evaluations">⭐</div>
            </div>
        </div>
    }

    <div class="thryv-section-card">
        <div class="thryv-section-header">
            <div>
                <h3>Assigned Books</h3>
                <p>Live view of active assignments based on the current stage of the day.</p>
            </div>

            <div class="thryv-section-badge">
                @assignedBooks.Count records
            </div>
        </div>

        <div class="thryv-table-wrapper">
            <table class="thryv-custom-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>KGEN Code</th>
                        <th>LSA Code</th>
                        <th>Book</th>
                        <th>Stage</th>
                        <th>Stage Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (assignedBooks.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="thryv-empty-row">
                                No assigned books available to display today.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in assignedBooks)
                        {
                            <tr>
                                <td>
                                    <div class="thryv-employee-cell">
                                        <div class="thryv-employee-avatar">👤</div>
                                        <div>
                                            <div class="thryv-employee-name">@item.EmployeeName</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="thryv-code-pill">@item.KgenCode</span>
                                </td>
                                <td>
                                    <span class="thryv-code-pill secondary">@item.LsaCode</span>
                                </td>
                                <td>@item.BookName</td>
                                <td>
                                    <span class="thryv-stage-pill">
                                        @item.Stage
                                    </span>
                                </td>
                                <td>@(item.StageDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private DashboardStatsDto stats = new DashboardStatsDto();
    private List<AssignedBookDashboardDto> assignedBooks = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await DashboardService.GetDashboardSummaryAsync();

            if (result is not null)
            {
                stats = result.Stats ?? new DashboardStatsDto();
                assignedBooks = result.AssignedBooks ?? new List<AssignedBookDashboardDto>();
            }
            else
            {
                stats = new DashboardStatsDto();
                assignedBooks = new List<AssignedBookDashboardDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString());
            stats = new DashboardStatsDto();
            assignedBooks = new List<AssignedBookDashboardDto>();
        }
        finally
        {
            loading = false;
        }
    }
}