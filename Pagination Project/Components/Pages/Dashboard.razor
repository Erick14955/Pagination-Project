@page "/dashboard"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Pagination_Project.Models
@using Pagination_Project.Services
@inject IDashboardService DashboardService
@layout Pagination_Project.Components.Layout.DashboardLayout
@rendermode InteractiveServer

<PageTitle>Dashboard - BibliotecaApp</PageTitle>

<div class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <h2 class="dashboard-title">Dashboard General</h2>
            <p class="dashboard-subtitle">Resumen rápido del sistema y listado actual de libros asignados.</p>
        </div>
    </div>

    @if (loading)
    {
        <p>Cargando estadísticas...</p>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">Total Usuarios</span>
                    <div class="stat-number">@stats.TotalUsers</div>
                </div>
                <div class="stat-icon blue">👥</div>
            </div>

            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">Total Empleados</span>
                    <div class="stat-number">@stats.TotalEmployees</div>
                </div>
                <div class="stat-icon indigo">👤</div>
            </div>

            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">Total Libros</span>
                    <div class="stat-number">@stats.TotalBooks</div>
                </div>
                <div class="stat-icon amber">📚</div>
            </div>

            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">Total Evaluaciones</span>
                    <div class="stat-number">@stats.TotalEvaluations</div>
                </div>
                <div class="stat-icon purple">⭐</div>
            </div>
        </div>
    }

    <div class="section-card">
        <div class="section-header">
            <div>
                <h3>Libros Asignados</h3>
                <p>Vista real del listado de asignaciones activas según la etapa del día.</p>
            </div>

            <div class="section-badge">
                @assignedBooks.Count registros
            </div>
        </div>

        <div class="table-wrapper">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Empleado</th>
                        <th>KGEN Code</th>
                        <th>LSA Code</th>
                        <th>Libro</th>
                        <th>Etapa</th>
                        <th>Fecha Etapa</th>
                    </tr>
                </thead>
                <tbody>
                    @if (assignedBooks.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="empty-row">
                                No hay libros asignados para mostrar hoy.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in assignedBooks)
                        {
                            <tr>
                                <td>
                                    <div class="employee-cell">
                                        <div class="employee-avatar">👤</div>
                                        <div>
                                            <div class="employee-name">@item.EmployeeName</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="code-pill">@item.KgenCode</span>
                                </td>
                                <td>
                                    <span class="code-pill secondary">@item.LsaCode</span>
                                </td>
                                <td>@item.BookName</td>
                                <td>
@*                                     <span class="stage-badge @GetStageClass(item.Stage)">
                                        @item.Stage
                                    </span> *@
                                    @item.Stage
                                </td>
                                <td>@(item.StageDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private DashboardStatsDto stats = new DashboardStatsDto();
    private List<AssignedBookDashboardDto> assignedBooks = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await DashboardService.GetDashboardSummaryAsync();

            if (result is not null)
            {
                stats = result.Stats ?? new DashboardStatsDto();
                assignedBooks = result.AssignedBooks ?? new List<AssignedBookDashboardDto>();
            }
            else
            {
                stats = new DashboardStatsDto();
                assignedBooks = new List<AssignedBookDashboardDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString());
            stats = new DashboardStatsDto();
            assignedBooks = new List<AssignedBookDashboardDto>();
        }
        finally
        {
            loading = false;
        }
    }

    // private string GetStageClass(string stage)
