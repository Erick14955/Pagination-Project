@page "/"
@page "/login"
@inject NavigationManager Navigation
@layout Pagination_Project.Components.Layout.LoginLayout

<PageTitle>Iniciar Sesión</PageTitle>

<div class="thryv-login-page">
    <div class="thryv-login-card">
        <div class="thryv-login-panel">
            <div class="thryv-logo-row">
                <div class="thryv-logo-mark">T</div>
                <div class="thryv-logo-text">
                    <strong>Evaluations</strong>
                    <span>Pagination evaluation system</span>
                </div>
            </div>

            <h2 class="thryv-login-title">Welcome back</h2>
            <p class="thryv-login-subtitle">
                Sign in to continue to your dashboard.
            </p>

            <form method="post" action="/account/login">
                <input type="hidden" name="ReturnUrl" value="/dashboard" />

                <div class="thryv-form-group">
                    <label>User</label>
                    <input name="Username"
                           class="thryv-input"
                           placeholder="Enter your username"
                           maxlength="50"
                           autocomplete="username" />
                </div>

                <div class="thryv-form-group">
                    <label>Password</label>
                    <input name="Password"
                           type="password"
                           class="thryv-input"
                           placeholder="••••••••"
                           maxlength="100"
                           autocomplete="current-password" />
                </div>

                @if (_mostrarError)
                {
                    <div class="thryv-error">
                        Incorrect user or password.
                    </div>
                }

                <button type="submit" class="thryv-login-button">
                    Login
                </button>
            </form>

            <div class="thryv-panel-footer">
                Secure access to your evaluation workspace
            </div>
        </div>
    </div>
</div>

@code {
    private bool _mostrarError;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        _mostrarError = query.ContainsKey("error");
    }
}