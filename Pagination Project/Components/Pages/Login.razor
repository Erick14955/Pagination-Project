@page "/"
@page "/login"
@using System.Net.Http.Json
@using Pagination_Project.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@layout Pagination_Project.Components.Layout.LoginLayout
@rendermode InteractiveServer

<PageTitle>Iniciar Sesión</PageTitle>

<div class="login-container">
    <div class="login-box">
        <div class="login-header">
            <h2>📚 Evaluations</h2>
            <p>Pagination evaluation system</p>
        </div>

        <EditForm Model="_model" OnValidSubmit="ValidarLogin" FormName="LoginForm">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label style="text-align: center;">User</label>
                <InputText @bind-Value="_model.Username" class="form-control" placeholder="Nombre" maxlength="20" style="text-align: center;" />
                <ValidationMessage For="@(() => _model.Username)" />
            </div>

            <div class="form-group">
                <label style="text-align: center;">Password</label>
                <InputText @bind-Value="_model.Password" type="password" class="form-control" placeholder="••••••••" maxlength="15" style="text-align: center;" />
                <ValidationMessage For="@(() => _model.Password)" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="validation-message" style="margin-bottom:12px;">
                    @_errorMessage
                </div>
            }

            <button type="submit" class="btn-login" disabled="@_loading">
                @(_loading ? "Validating..." : "Login")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private LoginRequest _model = new();
    private bool _loading;
    private string? _errorMessage;

    private async Task ValidarLogin()
    {
        _loading = true;
        _errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", _model);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

                if (result?.Success == true)
                {
                    Navigation.NavigateTo("/Home");
                    return;
                }

                _errorMessage = result?.Message ?? "Unable to log in.";
            }
            else
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                _errorMessage = result?.Message ?? "Incorrect user or password.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}